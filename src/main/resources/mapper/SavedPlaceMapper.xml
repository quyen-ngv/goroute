<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ds.goroute.mapper.SavedPlaceMapper">

    <resultMap id="SavedPlaceResultMap" type="com.ds.goroute.entity.SavedPlace">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="placeId" column="place_id"/>
        <result property="itemType" column="item_type"/>
        <result property="customPlaceId" column="custom_place_id"/>
        <result property="name" column="name"/>
        <result property="address" column="address"/>
        <result property="lat" column="lat"/>
        <result property="lng" column="lng"/>
        <result property="category" column="category"/>
        <result property="rating" column="rating"/>
        <result property="photoUrl" column="photo_url"/>
        <result property="tags" column="tags" typeHandler="org.apache.ibatis.type.ArrayTypeHandler"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert">
        INSERT INTO saved_places (id, user_id, place_id, item_type, custom_place_id, name, address, lat, lng, category, rating, photo_url, tags, created_at)
        VALUES (#{id}, #{userId}, #{placeId}, #{itemType}, #{customPlaceId}, #{name}, #{address}, #{lat}, #{lng}, #{category}, #{rating}, #{photoUrl}, #{tags}, #{createdAt})
    </insert>

    <select id="findById" resultMap="SavedPlaceResultMap">
        SELECT * FROM saved_places WHERE id = #{id}
    </select>

    <select id="findByUserId" resultMap="SavedPlaceResultMap">
        SELECT * FROM saved_places 
        WHERE user_id = #{userId}
        <if test="category != null">
            AND category = #{category}
        </if>
        <if test="itemType != null">
            AND item_type = #{itemType}
        </if>
        ORDER BY created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="findByUserIdAndPlaceId" resultMap="SavedPlaceResultMap">
        SELECT * FROM saved_places 
        WHERE user_id = #{userId} AND place_id = #{placeId} AND item_type = #{itemType}
    </select>

    <update id="updateTags">
        UPDATE saved_places 
        SET tags = #{tags}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM saved_places WHERE id = #{id}
    </delete>

</mapper>
